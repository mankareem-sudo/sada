# Sada — Environment Variables Template
# Copy this file to .env and fill in real values for production.

# === Database ===
# For local dev: SQLite
DATABASE_URL="file:/home/z/my-project/db/custom.db"
# For production: PostgreSQL (Supabase, Neon, Railway, or self-hosted)
# DATABASE_URL="postgresql://user:password@host:5432/sada?schema=public"

# === Auth ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# === Cloudflare R2 (audio storage) ===
# Sign up at https://cloudflare.com — free 10GB + free egress
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="sada-audio"
R2_PUBLIC_URL=""

# === AI Transcription (z-ai-web-dev-sdk) ===
# Already configured via .z-ai-config file
# ZAI_API_KEY=""

# === App Config ===
NEXT_PUBLIC_APP_NAME="Sada"
NEXT_PUBLIC_APP_NAME_AR="صدى"
NEXT_PUBLIC_DEVELOPER="Sada Team"
NEXT_PUBLIC_SUPPORT_EMAIL="support@sada.app"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# === Optional: Donations ===
# Ko-fi, Buy Me a Coffee, PayPal links (used in SupportModal)
NEXT_PUBLIC_KOFI_URL="https://ko-fi.com/sada"
NEXT_PUBLIC_BMC_URL="https://buymeacoffee.com/sada"
NEXT_PUBLIC_PAYPAL_URL="https://paypal.me/sada"

# === Optional: Analytics ===
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
