# Development (SQLite)
# For production: copy .env.example to .env and fill in real values

DATABASE_URL=file:/home/z/my-project/db/custom.db

# Production environment variables (copy these to your prod .env)
# DATABASE_URL="postgresql://user:pass@host:5432/sada?schema=public"
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL="https://your-domain.com"

# Optional: Cloudflare R2 for audio storage
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY=""
# R2_SECRET_KEY=""
# R2_BUCKET="sada-audio"

# Optional: For AI transcription (already integrated via z-ai-web-dev-sdk)
# ZAI_API_KEY=""

# App config
NEXT_PUBLIC_APP_NAME="Sada"
NEXT_PUBLIC_APP_NAME_AR="صدى"
NEXT_PUBLIC_DEVELOPER="Sada Team"
NEXT_PUBLIC_SUPPORT_EMAIL="support@sada.app"
