// Sada (صدى) — Voice-based Arabic social platform
// Prisma schema — Production-ready
// For production with PostgreSQL: change provider to "postgresql"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Use "postgresql" for production
  // Use "sqlite" for local dev
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  username     String      @unique
  name         String
  bio          String?
  avatarColor  String      @default("#8b5cf6")
  passwordHash String?
  isAdmin      Boolean     @default(false)
  // Onboarding
  onboarded    Boolean     @default(false)
  interests    String?     // comma-separated topics
  // Push (later)
  fcmToken     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sessions     Session[]
  voiceNotes   VoiceNote[]
  likes        Like[]
  reports      Report[]
  comments     Comment[]
  bookmarks    Bookmark[]
  donations    SupportDonation[]
  notificationsReceived Notification[] @relation("NotifRecipient")
  notificationsTriggered Notification[] @relation("NotifActor")

  // Following = users I follow
  following    Follow[]    @relation("Follower")
  // Followers = users who follow me
  followers    Follow[]    @relation("Followee")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([token])
}

model Prompt {
  id         String      @id @default(cuid())
  text       String
  // YYYY-MM-DD date string for which day this prompt is for
  date       String      @unique
  topic      String?     // "career", "life", "learning", "health", "relationships", "creativity"
  createdAt  DateTime    @default(now())

  voiceNotes VoiceNote[]
}

model VoiceNote {
  id           String    @id @default(cuid())
  promptId     String?
  prompt       Prompt?   @relation(fields: [promptId], references: [id], onDelete: SetNull)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Base64-encoded audio data (Opus/WebM)
  audioData    String
  mimeType     String    @default("audio/webm")
  durationSec  Int
  // Optional user-written description / title for the voice note
  description  String?
  // Optional text transcript (filled later by AI or manual)
  transcript   String?
  plays        Int       @default(0)
  createdAt    DateTime  @default(now())

  likes        Like[]
  reports      Report[]
  comments     Comment[]
  bookmarks    Bookmark[]

  @@index([userId])
  @@index([promptId])
  @@index([createdAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User     @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId])
}

model Like {
  id          String    @id @default(cuid())
  userId      String
  voiceNoteId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceNote   VoiceNote @relation(fields: [voiceNoteId], references: [id], onDelete: Cascade)

  @@unique([userId, voiceNoteId])
  @@index([voiceNoteId])
}

model Comment {
  id          String    @id @default(cuid())
  userId      String
  voiceNoteId String
  content     String
  // For threaded replies
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceNote   VoiceNote @relation(fields: [voiceNoteId], references: [id], onDelete: Cascade)

  @@index([voiceNoteId])
  @@index([userId])
  @@index([parentId])
}

model Bookmark {
  id          String    @id @default(cuid())
  userId      String
  voiceNoteId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceNote   VoiceNote @relation(fields: [voiceNoteId], references: [id], onDelete: Cascade)

  @@unique([userId, voiceNoteId])
  @@index([userId])
}

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  voiceNoteId String
  // reason: "religion" | "politics" | "insult" | "spam" | "other"
  reason      String
  comment     String?
  // status: "pending" | "reviewed" | "removed" | "dismissed"
  status      String    @default("pending")
  createdAt   DateTime  @default(now())

  reporter    User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  voiceNote   VoiceNote @relation(fields: [voiceNoteId], references: [id], onDelete: Cascade)

  @@index([voiceNoteId])
  @@index([status])
}

model Notification {
  id          String   @id @default(cuid())
  // recipient = who receives the notification
  recipientId String
  recipient   User     @relation("NotifRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  // actor = who triggered it
  actorId     String
  actor       User     @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  // type: "like" | "follow" | "comment" | "reply" | "system"
  type        String
  voiceNoteId String?
  commentId   String?
  // preview text
  text        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, read])
  @@index([createdAt])
}

model SupportDonation {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String
  email      String?
  amount     Float
  currency   String   @default("USD")
  method     String   @default("manual") // "kofi" | "buymeacoffee" | "paypal" | "manual"
  message    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
