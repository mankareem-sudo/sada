{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run vercel-build",
  "installCommand": "bun install",
  "github": {
    "silent": true
  },
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/bots/activate/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/bots/seed/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/bots/fix-avatars/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/bots/cleanup/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/bots/connect/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/moderation/scan/route.ts": {
      "maxDuration": 120
    }
  }
}
